{
  "extends": "@repo/typescript/base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "~/components": ["./src/components"],
      "~/utils": ["./src/lib/utils"],
      "~/lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "public/**/*"
  ],
  "exclude": ["node_modules"]
}
